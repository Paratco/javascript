{
  "name": "@paratco/eslint-config",
  "version": "3.4.0",
  "type": "module",
  "author": "Paratco",
  "license": "MIT",
  "description": "Paratco ESLint Config",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">= 1.3.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Paratco/javascript.git"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "react",
    "node",
    "node.js",
    "lint"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "scripts": {
    "lint": "bunx --bun eslint --max-warnings=0 --cache",
    "lint:fix": "bunx --bun eslint --cache --fix",
    "build:check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build:js": "bun build ./src/index.ts --outdir=dist --target=node --format=esm --packages=external --sourcemap=linked",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "release": "semantic-release",
    "release-dry-debug": "semantic-release --no-ci -d --debug",
    "release-dry": "semantic-release --no-ci -d"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.9.1",
    "@eslint-react/kit": "^5.9.1",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/types": "^8.61.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-unicorn": "68.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "typescript-eslint": "8.61.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^25.0.5",
    "typescript": "~6.0.3",
    "@types/bun": "latest"
  }
}
